# Chave da OpenAI — NUNCA commite este arquivo preenchido.
# Crie em https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-sua-chave-aqui

# Modelo de imagem (gpt-image-1.5 | gpt-image-2 | gpt-image-1)
# Default: gpt-image-1.5
OPENAI_IMAGE_MODEL=gpt-image-1.5

# Modelo de texto p/ pré-processar (traduzir+enriquecer) o prompt da imagem
# Default: gpt-4o-mini
OPENAI_TEXT_MODEL=gpt-4o-mini

# Supabase — rostos persistidos
# URL do projeto (painel > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
# Chave anon (public) — pode ficar no frontend
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui
# Service role — SERVER-SIDE ONLY. Nunca expor no frontend nem commitar.
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-aqui
